---
import type { BlogPost } from '../../types/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<aside class="mt-12 p-6 sm:p-8 bg-[#F8FAFC] border border-[#0F172A]/10 rounded-2xl flex flex-col sm:flex-row items-center sm:items-start gap-6">
  <img
    src={post.authorAvatar}
    alt={post.author}
    class="w-20 h-20 rounded-full border-4 border-[#10B981]/20 shadow-lg shrink-0"
    loading="lazy"
    decoding="async"
  />
  <div class="text-center sm:text-left">
    <p class="text-[10px] font-black uppercase tracking-widest text-[#0F172A]/40 mb-1">Written by</p>
    <p class="font-black font-manrope text-xl text-[#0F172A] mb-1">{post.author}</p>
    <p class="text-sm text-[#0F172A]/50 font-semibold">{post.authorRole}</p>
  </div>
</aside>
