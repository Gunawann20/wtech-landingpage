---
import type { BlogPost } from '../../types/blog';
import BlogBreadcrumb from './BlogBreadcrumb.astro';
import { formatBlogDate } from '../../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const formattedDate = formatBlogDate(post.pubDate);
---

<header class="pt-28 sm:pt-32 lg:pt-36 pb-10 sm:pb-12">
  <div class="container mx-auto px-4 sm:px-6 lg:px-12 max-w-4xl">
    <BlogBreadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog' },
        { label: post.title, href: `/blog/${post.slug}` },
      ]}
    />
    <div class="flex flex-wrap items-center gap-3 mb-6 text-[10px] font-black uppercase tracking-widest text-[#0F172A]/40">
      <time datetime={post.pubDate}>{formattedDate}</time>
      {post.updatedDate && (
        <>
          <span aria-hidden="true">·</span>
          <span>Updated {formatBlogDate(post.updatedDate)}</span>
        </>
      )}
      <span aria-hidden="true">·</span>
      <span>{post.readTime} min read</span>
      <span aria-hidden="true">·</span>
      <span itemprop="author">{post.author}</span>
    </div>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black font-manrope tracking-tighter leading-tight mb-6">
      {post.title}
    </h1>
    <p class="text-base sm:text-lg text-[#0F172A]/60 leading-relaxed mb-8">{post.description}</p>
    {post.tags.length > 0 && (
      <ul class="flex flex-wrap gap-2 mb-8" aria-label="Tags">
        {post.tags.map((tag) => (
          <li class="px-3 py-1 bg-[#10B981]/10 text-[#10B981] text-[10px] font-black uppercase tracking-widest rounded-full">
            {tag}
          </li>
        ))}
      </ul>
    )}
    <figure class="rounded-2xl overflow-hidden border border-[#0F172A]/10 shadow-xl">
      <img src={post.image} alt="" class="w-full aspect-[16/9] object-cover" loading="eager" decoding="async" />
    </figure>
  </div>
</header>
