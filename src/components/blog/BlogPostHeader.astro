---
import type { BlogPost } from '../../types/blog';
import BlogBreadcrumb from './BlogBreadcrumb.astro';
import { formatBlogDateShort } from '../../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const formattedDate = formatBlogDateShort(post.pubDate);
const category = post.tags[0] ?? 'Article';
---

<header>
  <BlogBreadcrumb
    variant="editorial"
    items={[
      { label: 'Home', href: '/' },
      { label: 'Our Blogs', href: '/blog' },
      { label: category, href: `/blog/${post.slug}` },
    ]}
  />

  <h1 class="text-[2rem] sm:text-4xl lg:text-[2.625rem] font-bold font-manrope leading-[1.15] text-[#0F172A] mb-5 max-w-4xl">
    {post.title}
  </h1>

  <div class="flex flex-wrap items-center justify-between gap-4 pb-6 mb-8 border-b border-[#0F172A]/8">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <div class="flex items-center gap-2.5 min-w-0">
        {post.authorAvatar ? (
          <img
            src={post.authorAvatar}
            alt={post.author}
            class="w-8 h-8 rounded-full object-cover shrink-0"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div
            class="w-8 h-8 rounded-full bg-[#E2E8F0] flex items-center justify-center shrink-0"
            aria-hidden="true"
          >
            <i class="ti ti-user text-sm text-[#64748B]"></i>
          </div>
        )}
        <span class="text-sm font-medium text-[#0F172A]" itemprop="author">{post.author}</span>
      </div>

      <span class="px-3 py-1 bg-[#F1F5F9] text-[#475569] text-xs font-medium rounded-full">
        {category}
      </span>

      <span class="inline-flex items-center gap-1.5 text-sm text-[#64748B]">
        <i class="ti ti-clock text-[15px]" aria-hidden="true"></i>
        {post.readTime} min read
      </span>

      <time datetime={post.pubDate} class="inline-flex items-center gap-1.5 text-sm text-[#64748B]">
        <i class="ti ti-calendar text-[15px]" aria-hidden="true"></i>
        {formattedDate}
      </time>
    </div>

    <button
      type="button"
      class="hidden sm:inline-flex w-9 h-9 items-center justify-center rounded-full border border-[#0F172A]/10 text-[#64748B] hover:text-[#10B981] hover:border-[#10B981]/30 transition-colors shrink-0"
      aria-label="Save article"
    >
      <i class="ti ti-heart text-lg"></i>
    </button>
  </div>

  <figure class="rounded-[1.25rem] overflow-hidden mb-10 sm:mb-12">
    <img
      src={post.image}
      alt={post.title}
      class="w-full aspect-[16/9] object-cover"
      loading="eager"
      decoding="async"
    />
  </figure>
</header>
