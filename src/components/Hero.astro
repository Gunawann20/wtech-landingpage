---
import { site } from '../config/site';
---

<section class="min-h-[600px] sm:min-h-[700px] lg:min-h-[900px] pt-24 sm:pt-28 lg:pt-32 pb-12 sm:pb-16 lg:pb-20 flex items-center justify-center relative overflow-hidden">
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none -z-10">
    <span class="text-[120px] sm:text-[200px] lg:text-[360px] font-black text-[#0F172A]/[0.03] tracking-tighter font-manrope">WTECH</span>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-12 relative z-10 grid grid-cols-12 gap-8 lg:gap-12 items-center">
    <div class="col-span-12 lg:col-span-5">
      <div class="inline-block px-4 py-1.5 bg-[#10B981]/10 text-[#10B981] font-black text-[10px] tracking-[0.3em] uppercase rounded-full mb-6 sm:mb-8">
        Enterprise Software House
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black text-[#0F172A] font-manrope leading-[0.85] tracking-tighter mb-6 sm:mb-8">
        BUILD <br />
        <span class="text-outline">SMARTER</span> <br />
        SOLUTIONS
      </h1>
      <p class="text-base sm:text-lg lg:text-xl text-[#0F172A]/70 max-w-md leading-relaxed mb-8 sm:mb-12">
        Transforming complex ideas into intelligent digital solutions through custom engineering and AI-driven automation.
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap gap-4">
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto text-center bg-[#0F172A] text-white px-8 sm:px-10 py-4 sm:py-5 font-bold tracking-widest text-xs uppercase rounded-xs hover:bg-[#10B981] active:scale-95 transition-all shadow-xl shadow-[#0F172A]/10"
        >
          BOOK FREE CONSULTATION
        </a>
        <a href="#portfolio" class="w-full sm:w-auto text-center border border-[#0F172A] text-[#0F172A] px-8 sm:px-10 py-4 sm:py-5 font-bold tracking-widest text-xs uppercase rounded-xs hover:bg-[#0F172A] hover:text-white transition-all inline-block">
          VIEW PORTFOLIO
        </a>
      </div>
    </div>

    <div class="col-span-12 lg:col-span-7 relative">
      <div class="bg-white rounded-2xl shadow-2xl border border-[#0F172A]/5 overflow-hidden transform lg:rotate-2 hover:rotate-0 transition-transform duration-700">
        <div class="bg-[#F1F5F9] px-4 py-3 flex items-center gap-2 border-b border-[#0F172A]/10">
          <div class="flex gap-1.5 shrink-0">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
          </div>
          <div class="flex-1 ml-2 sm:ml-4 bg-white/50 rounded-md py-1.5 px-3 text-[10px] text-[#0F172A]/40 font-mono flex items-center gap-2 truncate">
            <i class="ti ti-lock text-[8px] shrink-0"></i>
            <span class="truncate">wtech.innovations/v3/dashboard</span>
          </div>
        </div>
        <div class="aspect-[16/10] bg-[#F8FAFC]">
          <img
            src="https://images.unsplash.com/photo-1763718528755-4bca23f82ac3?auto=format&w=1200&q=80&fit=crop"
            alt="Dashboard Analytics"
            class="w-full h-full object-cover"
            decoding="async"
            loading="lazy"
          />
        </div>
      </div>

      <div class="mt-6 lg:hidden bg-white p-6 rounded-xl shadow-2xl border border-[#0F172A]/5">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-[#10B981]/10 rounded-full flex items-center justify-center">
            <i class="ti ti-trending-up text-[#10B981] text-2xl"></i>
          </div>
          <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-[#0F172A]/40">System Efficiency</p>
            <p class="text-2xl font-black font-manrope text-[#0F172A]">+84.2%</p>
          </div>
        </div>
        <div class="w-full h-1 bg-[#F1F5F9] rounded-full overflow-hidden">
          <div class="w-[84%] h-full bg-[#10B981]"></div>
        </div>
      </div>

      <div class="absolute -bottom-10 -left-10 bg-white p-6 rounded-xl shadow-2xl border border-[#0F172A]/5 hidden lg:block transform -rotate-3">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-[#10B981]/10 rounded-full flex items-center justify-center">
            <i class="ti ti-trending-up text-[#10B981] text-2xl"></i>
          </div>
          <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-[#0F172A]/40">System Efficiency</p>
            <p class="text-2xl font-black font-manrope text-[#0F172A]">+84.2%</p>
          </div>
        </div>
        <div class="w-48 h-1 bg-[#F1F5F9] rounded-full overflow-hidden">
          <div class="w-[84%] h-full bg-[#10B981]"></div>
        </div>
      </div>
    </div>
  </div>
</section>
